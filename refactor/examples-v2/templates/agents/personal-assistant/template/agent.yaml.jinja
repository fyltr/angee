version: 1
kind: agent
name: {{ agent_name }}

template:
  active: agents/personal-assistant
  answers_file: .copier-answers.yml

user: {{ user }}
display_name: {{ display_name or user }}

model:
  provider: {{ provider }}
  name: {{ model }}

# Persistent memory volume scoped to this user. Survives agent restart/destroy
# unless explicitly purged.
volumes:
  memory:
    scope: agent
    driver: local-fs

workspace:
  root: agents/{{ agent_name }}/workspace
  env_file: .env
  sources:
    memory:
      subpath: memory
      persistent: true
      source: { kind: volume, volume: memory }

ports:
  http: { value: ${alloc.custom}, export_env: AGENT_HTTP_PORT }

# MCP servers, conditionally wired based on which credentials Django provided.
# `${connector.provider.user}` is a credential-resolver reference; the operator
# asks the registered resolver (typically Django's connector API) for a token
# at agent start, refreshes when expired, and never persists the token in
# angee.yaml.
mcp_servers:
  filesystem:
    transport: stdio
    command: ["npx", "-y", "@modelcontextprotocol/server-filesystem", "${workspace.root}"]

  operator:
    transport: streamable-http
    url: "${operator.url}/mcp"
    auth: { bearer_secret: agent-operator-token }

{% if 'gmail' in mcp_credentials %}
  gmail:
    transport: http
    url: ${mcp_credentials.gmail.url | default('https://gmail-mcp.example.com')}
    auth:
      bearer_credential: "${connector.gmail.{{ user }}}"
{% endif %}

{% if 'calendar' in mcp_credentials %}
  calendar:
    transport: http
    url: ${mcp_credentials.calendar.url | default('https://calendar-mcp.example.com')}
    auth:
      bearer_credential: "${connector.calendar.{{ user }}}"
{% endif %}

{% if 'google-drive' in mcp_credentials %}
  google-drive:
    transport: http
    url: ${mcp_credentials['google-drive'].url | default('https://drive-mcp.example.com')}
    auth:
      bearer_credential: "${connector.google-drive.{{ user }}}"
{% endif %}

services:
  {{ agent_name }}:
    tags: [agent, personal-assistant]
    runtime: container
    image: ghcr.io/fyltr/agent-claude:latest
    ports:
      - "${ports.http}:3007"
    env:
      ANGEE_AGENT_NAME: {{ agent_name }}
      ANGEE_AGENT_USER: {{ user }}
      ANGEE_OPERATOR_URL: "${operator.url}"
      ANGEE_OPERATOR_TOKEN: "${secret.agent-operator-token}"
      ANTHROPIC_API_KEY: "${secret.anthropic-api-key}"
    mounts:
      - { type: bind,   source: agents/{{ agent_name }}/workspace, target: /workspace }
      - { type: volume, source: memory, target: /workspace/memory }
    mcp_servers:
      - filesystem
      - operator
{% for cred in mcp_credentials %}
      - {{ cred }}
{% endfor %}

secrets:
  agent-operator-token:
    generated: true
    length: 32
    scope: agent
    permissions:
      - "agents.${name}.*"

provision:
  on_destroy:
    - { run: stop-service }
    # NOTE: memory volume preserved by default; --purge to delete it
