version: 1
kind: agent
name: {{ agent_name }}

template:
  active: agents/claude-angee-developer
  answers_file: .copier-answers.yml

model:
  provider: {{ provider }}
  name: {{ model }}

# ---------- Workspace: the agent's worktree + materialized sources ----------
# `source: django-angee` references the global stack source declared in
# angee.yaml. The agent only declares per-instance overrides (branch +
# worktree path). The operator does `git worktree add` off the shared cache
# clone — multiple agents share the local clone, each gets its own worktree.
workspace:
  root: agents/{{ agent_name }}/workspace
  env_file: .env
  sources:
    code:
      subpath: code
      source: django-angee
      mode: worktree
      ref: {{ base_branch }}
      branch: {{ branch }}
      worktree_path: ../django-angee.workspaces/${name}
      lock:
        commit: "<resolved-by-agent-init>"

# ---------- Template chaining: provision a stack INSIDE the worktree ----------
# After the worktree is materialized the operator runs the equivalent of
#   `angee init <stack-template> [path]` from inside `workdir`,
# using the same in-process operator code path as a top-level `angee init`.
# No nested operator process — just a second provisioning pass scoped to a
# different ANGEE_ROOT.
chain:
  - kind: stack
    template: stacks/angee-notes-dev
    workdir: ../django-angee.workspaces/{{ agent_name }}/{{ app_subpath }}
    root: ../django-angee.workspaces/{{ agent_name }}/{{ app_subpath }}/.angee
    inputs:
      project_name: angee-notes-{{ agent_name }}
      ANGEE_ROOT: .angee
      app_path: .
      django_port: ${ports.django}
      ui_port:    ${ports.ui}
    lifecycle:
      provision_on: agent.init
      # angee-notes-dev contains runtime: local services (Django, Vite),
      # so the chained stack runs as `dev` (compose + process-compose),
      # not `up` (compose-only).
      up_on:        { trigger: agent.start, mode: dev }
      down_on:      agent.stop
      destroy_on:   agent.destroy

# ---------- Ports: parent operator allocates these from its pool ----------
ports:
  django:     { value: ${alloc.django},     export_env: DJANGO_PORT }
  ui:         { value: ${alloc.ui},         export_env: UI_PORT, aliases: [WORKSPACE_VITE_PORT] }
  playwright: { value: ${alloc.playwright}, export_env: PLAYWRIGHT_MCP_PORT }

# ---------- MCP servers the agent connects to ----------
mcp_servers:
  filesystem:
    transport: stdio
    command: ["npx", "-y", "@modelcontextprotocol/server-filesystem", "${workspace.root}"]

  operator:
    transport: streamable-http
    url: "${operator.url}/mcp"
    auth:
      bearer_secret: agent-operator-token       # minted per-agent at init time

  playwright:
    transport: http
    url: "http://${service.playwright}/mcp"
    # Persistent dirs declared by the template are created by the operator on
    # first start, preserved across restarts, and removed on `destroy --purge`.
    # Their absolute paths are exposed as ${persist.<name>} for use below.
    persist:
      browser-data: { subpath: .playwright-data, scope: agent }
    runtime:
      kind: local-process
      workdir: agents/${name}
      command:
        - npx
        - -y
        - "@playwright/mcp@latest"
        - --port
        - "${ports.playwright}"
        - --host
        - 127.0.0.1
        - --browser
        - chrome
        - --user-data-dir
        - "${persist.browser-data}"
      env_file: .env
      health:
        http: "http://${service.playwright}/mcp/health"
        timeout: 30s

  inner-django:
    transport: http
    url: http://127.0.0.1:${ports.django}/mcp
    depends_on: [inner_stack.web]               # only available after inner stack is healthy

# ---------- The agent service itself ----------
services:
  {{ agent_name }}:
    tags: [agent, claude-code]
    runtime: local
    workdir: agents/{{ agent_name }}
    command: ["claude"]
    env_file: .env
    env:
      ANGEE_AGENT_NAME: {{ agent_name }}
      ANGEE_OPERATOR_URL: "${operator.url}"
      ANGEE_OPERATOR_TOKEN: "${secret.agent-operator-token}"
      ANTHROPIC_API_KEY: "${secret.anthropic-api-key}"
    mcp_servers: [filesystem, operator, playwright, inner-django]
    depends_on: [inner_stack.up, playwright]

# ---------- Per-agent secrets ----------
secrets:
  agent-operator-token:
    description: Bearer token the agent uses to call the parent operator.
    generated: true
    length: 32
    scope: agent
    permissions:                               # narrow the token to its own resources
      - "agents.${name}.read"
      - "agents.${name}.events.write"
      - "agents.${name}.messages.read"

# ---------- Lifecycle hooks ----------
# Chained stacks (see `chain:` above) are driven by their lifecycle.* triggers,
# so we don't list them here — those run at the right moments automatically.
provision:
  on_init:
    - { run: materialize-source, source: code }
    - { run: render-artifacts }
  on_start:
    - { run: start-mcp, server: playwright }
    - { run: start-service }
  on_stop:
    - { run: stop-service }
    - { run: stop-mcp,   server: playwright }
  on_destroy:
    - { run: stop-service }
    - { run: remove-worktree, keep_branch: true, keep_volumes: false }

# ---------- Files rendered at agent init ----------
artifacts:
  - { path: .env,       template: .env.jinja }
  - { path: CLAUDE.md,  template: CLAUDE.md.jinja }
  - { path: .mcp.json,  template: .mcp.json.jinja }
