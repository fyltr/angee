{
  "mcpServers": {
    "angee-files": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspace.root}"]
    },
    "angee-operator": {
      "type": "http",
      "url": "${operator.url}/mcp",
      "headers": {
        "Authorization": "Bearer ${secret.agent-operator-token}"
      }
    },
    "playwright": {
      "type": "http",
      "url": "http://127.0.0.1:${ports.playwright}/mcp"
    },
    "inner-django": {
      "type": "http",
      "url": "http://127.0.0.1:${ports.django}/mcp"
    }
  }
}
