# Per-agent env. Generated by angee-operator. DO NOT EDIT MANUALLY.
ANGEE_AGENT_NAME={{ agent_name }}
ANGEE_AGENT_BRANCH={{ branch }}
ANGEE_AGENT_BASE_BRANCH={{ base_branch }}
ANGEE_OPERATOR_URL=${operator.url}
ANGEE_OPERATOR_TOKEN=${secret.agent-operator-token}

# Inner-stack discovery. Hosts are rewritten per-consumer by the operator
# (127.0.0.1 for host-process agents, host.docker.internal for containerized).
INNER_DJANGO_URL=http://${service.web}
INNER_UI_URL=http://${service.ui}
PLAYWRIGHT_MCP_URL=http://${service.playwright}/mcp

# LLM
ANTHROPIC_API_KEY=${secret.anthropic-api-key}
ANGEE_AGENT_MODEL={{ model }}
